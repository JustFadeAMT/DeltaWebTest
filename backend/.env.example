# ── App Settings ──────────────────────────────────────────────────
DEBUG=true
ENVIRONMENT=testnet

# ── Database ──────────────────────────────────────────────────────
# SQLite (default for dev):
DATABASE_URL=sqlite+aiosqlite:///./delta_neutral.db
# PostgreSQL (for production):
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/delta_neutral

# ── Deribit API ───────────────────────────────────────────────────
# Get testnet keys from https://test.deribit.com
DERIBIT_API_KEY=
DERIBIT_API_SECRET=

# ── PnL Snapshot Interval (seconds) ──────────────────────────────
SNAPSHOT_INTERVAL_SECONDS=30

# ── CORS Origins ─────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Risk Limits ──────────────────────────────────────────────────
MAX_PAPER_POSITIONS=20
MAX_LIVE_POSITIONS=5
MAX_ORDER_NOTIONAL_USD=50000
MAX_DAILY_LOSS_USD=10000
MAX_HEDGE_SIZE=100
